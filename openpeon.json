{
  "cesp_version": "1.0",
  "name": "cxq-peon",
  "display_name": "Baby & Friends Sound Pack",
  "version": "1.0.0",
  "description": "Cute notification sounds featuring Baby, Datong, and Gali for system events.",
  "author": {
    "name": "cxq",
    "github": "cxq-0101"
  },
  "license": "CC-BY-NC-4.0",
  "language": "zh-CN",
  "categories": {
    "session.start": {
      "sounds": [{ "file": "sounds/baby-start.mp3", "label": "开始" }]
    },
    "task.complete": {
      "sounds": [{ "file": "sounds/baby-ok.mp3", "label": "ok" }]
    },
    "task.error": {
      "sounds": [{ "file": "sounds/baby-error.mp3", "label": "错误" }]
    }
  }
